# Copy to .env and fill in the keys you have. M516 is free-tier-first (ADR-002): a provider with a
# missing key is skipped, not an error. Never commit the real .env file.

# General
LOG_LEVEL=INFO
DATABASE_URL=

# Discovery providers (docs/22_BUILD_PLAN.md WP1, ADR-004: Netlas + Criminal IP first)
NETLAS_API_KEY=
CRIMINALIP_API_KEY=

# Shodan InternetDB (ADR-011) needs no API key — enabled automatically, non-commercial licence only.

# Censys (added post-WP1). Free tier only supports the direct host-lookup-by-IP endpoint, not domain
# search — this adapter resolves domain -> IP itself, same pattern as InternetDB.
CENSYS_API_KEY=

# CVE enrichment (docs/22_BUILD_PLAN.md WP2). Optional: works unauthenticated at 5 req/30s,
# 50 req/30s with a free key from https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# API / pipeline (docs/22_BUILD_PLAN.md WP5, docs/05_API_DESIGN.md). All optional — sensible defaults
# in m516/config.py.
# Which compliance pack POST /api/scans uses when the request omits pack_id. No default — required
# either here or per-request, so the engine never silently guesses.
DEFAULT_PACK_ID=nigeria-banking
# Where compliance packs live on disk (id -> <PACKS_ROOT>/<id>/pack.yaml).
PACKS_ROOT=packs
# Where rendered scan PDFs are written (git-ignored; not meant to persist across deployments).
REPORT_OUTPUT_DIR=.reports
# ChromaDB persistent store for embedded pack clauses (git-ignored).
CHROMA_PATH=.chroma
