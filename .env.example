# Copy to .env and fill in the keys you have. M516 is free-tier-first (ADR-002): a provider with a
# missing key is skipped, not an error. Never commit the real .env file.

# General
LOG_LEVEL=INFO
DATABASE_URL=

# Discovery providers (docs/22_BUILD_PLAN.md WP1, ADR-004: Netlas + Criminal IP first)
NETLAS_API_KEY=
CRIMINALIP_API_KEY=

# Shodan InternetDB (ADR-011) needs no API key — enabled automatically, non-commercial licence only.
